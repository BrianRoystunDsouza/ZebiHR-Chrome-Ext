{
  "manifest_version": 3,
  "name": "ZebiHR Work Hours Calculator (Brian)",
  "version": "1.0",
  "description": "Calculates total working hours on ZebiHR.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "cookies",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "https://synergyapi.helixbeat.com/*",
    "https://*.helixbeat.com/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": "logo1.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.helixbeat.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
